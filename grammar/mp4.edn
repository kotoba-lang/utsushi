;; grammar/mp4.edn — ISO BMFF (MP4/MOV) の EDN binary 文法（kasane.decode 用, ADR §1）。
;; R0 は utsushi.container の手書きスキャナで box ツリーを取り、kasane が立ち上がり次第
;; この文法 + kasane.decode に委譲する。`mdat` payload は decode せず blob(CID) 化する。
{:meta {:id :mp4 :endian :big}
 :types
 {:box
  [{:id :size      :type :u32}
   {:id :type      :type :str :encoding :ascii :size 4}
   {:id :largesize :type :u64 :when [:expr [:= [:field :size] 1]]}
   {:id :payload   :type :switch :on [:field :type]
    :cases {;; container box → 子 box 列を再帰
            "moov" {:type :seq :until :box-end :of :box}
            "trak" {:type :seq :until :box-end :of :box}
            "mdia" {:type :seq :until :box-end :of :box}
            "minf" {:type :seq :until :box-end :of :box}
            "stbl" {:type :seq :until :box-end :of :box}
            "moof" {:type :seq :until :box-end :of :box}
            "traf" {:type :seq :until :box-end :of :box}
            ;; メディア実体は読まず境界のみ（★ CID 化は呼び出し側）
            "mdat" {:type :blob :size [:expr [:box-remaining]]}
            :default {:type :blob :size [:expr [:box-remaining]]}}}]}}
