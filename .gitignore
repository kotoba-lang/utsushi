/.cpcache/
/.clj-kondo/.cache/
/.lsp/.cache/
/target/
*.class
.DS_Store
;; メディア実体は持ち込まない（B2+DataLad / Vault blob 経由）。
;; 例外: test/fixtures 配下の数KB級テスト用実ファイルは org-iso-h264/org-iso-aac
;; 前例（resources/*/fixtures/sample.*）に倣いコミット対象（B2/DataLadの対象は
;; もっと大きい実データセットのみ）。
*.mp4
*.mov
*.mkv
*.webm
*.ts
*.wav
*.aac
*.h264
*.h265
!resources/utsushi/fixtures/*.mp4
;; ADR-2607122000 §4/Migration手順5: org-iso-h264 golden vector (flat16-dc-only),
;; copied verbatim for utsushi.codec.store's integration test — same "small
;; real fixture is committed" exception as the .mp4 rule above.
!resources/utsushi/fixtures/*.h264
