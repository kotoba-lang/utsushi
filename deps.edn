;; utsushi（映し）— 時間ベースメディア（動画/音声）の純 cljc + EDN ライブラリ。
;; 設計 SSoT: 90-docs/adr/2606272200-utsushi-video-edn-filtergraph.md (ADR-2606272200)
;;
;; 方針（ADR §0、2026-07-08 改訂 — reverse-domain split）:
;;   ① コンテナ demux/mux/remux/bytes/blob … org-iso-isobmff へ抽出済み（ISO/IEC 14496-12、
;;      kasane.isobmff と統合）。utsushi はそれに依存する filtergraph オーケストレータ。
;;   ② ビットストリーム（NAL/SPS/ADTS/Opus framing）… org-iso-h264/org-iso-aac/org-ietf-opus
;;      へ新規実装として切り出し済み（utsushi.bitstream は未実装 TODO stub だったため）。
;;      utsushi.codec は org-iso-h264 だけを消費する（avcC埋め込みSPSの実解析）。
;;      AAC/Opusは demux 済みsampleに対して適用対象が存在しないため未配線
;;      （理由は utsushi.codec のdocstring参照）。
;;   ③ codec カーネル        … R0 opaque / R1 capability-gated native（kotoba-clj host word）
;;   ④ filtergraph           … kotoba defgraph への射影（データ）、Pregel BSP 実行
;; utsushi 自身に残るのは filtergraph オーケストレーション + capability/effect/gas モデルの
;; kotoba 鏡写しという「utsushi 固有の知的財産」だけ。コンテナ/コーデック仕様の実装は
;; 各 reverse-domain repo に委ねる（com-junkawasaki/root ADR 前例2607072500）。
;;
;; decode-state Store（ADR-2607122000 Migration手順5）: org-iso-h264 を
;; a6ed858（framing/SPS/PPS のみ）→ daccb23（h264.decode/decode-idr-frame、
;; 実画素 baseline intra decode 追加、Wave 3）へ更新。langchain は
;; utsushi.codec.store の `:db-api` 注入パターン（MemStore ≡ DatomicStore
;; contract、actor 系と同型）の手本かつ実体（langchain.db/api）。
{:paths ["src" "resources"]
 :deps  {io.github.kotoba-lang/org-iso-isobmff {:git/sha "50fbdbbeb5be30d8cab63877b220b7079a23b4a1"}
         io.github.kotoba-lang/org-iso-h264    {:git/sha "daccb23a139a251ff0e63faaaf8040c8fd18680b"}
         io.github.kotoba-lang/langchain       {:git/sha "0f966d06c93d7fc76b0790fdece4c391dc257eb1"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]}
       ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
       :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
